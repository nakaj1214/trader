# OpenAI API (Phase 3以降で使用)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Google Sheets API
GOOGLE_CREDENTIALS_JSON=path/to/credentials.json

# Slack Incoming Webhook
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz

# Slack Bot Token（チャート画像アップロード用）
SLACK_BOT_TOKEN=xoxb-your-bot-token-here

# LINE Messaging API (LINE通知を有効にする場合)
LINE_CHANNEL_ACCESS_TOKEN=your-channel-access-token
LINE_USER_ID=your-line-user-id

# J-Quants API（日本株ファンダメンタルデータ補完）Phase 22（V2推奨）
# https://jpx-jquants.com/ で V2 APIキーを取得（推奨）
JQUANTS_API_KEY=your-jquants-api-key
# V1 フォールバック（非推奨・廃止予定）: JQUANTS_API_KEY 未設定時のみ使用される
# JQUANTS_MAIL_ADDRESS=your-email@example.com
# JQUANTS_PASSWORD=your-jquants-password

# Finnhub API（US 株ニュース・センチメント）Phase 18
# https://finnhub.io/register で無料登録後に取得
FINNHUB_API_KEY=your-finnhub-api-key

# Financial Modeling Prep API（グローバル財務データ補完）Phase 19
# https://site.financialmodelingprep.com/ で無料登録後に取得（250 req/日）
FMP_API_KEY=your-fmp-api-key
